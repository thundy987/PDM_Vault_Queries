-- =============================================
-- Description: Returns files ranked by version count, highest first.
--              Includes file path to distinguish files with the same name
--              in different vault locations.
-- =============================================

;With Columns as(
	Select	
		d.Filename as file_name,
		p.Path as file_path,
		r.RevNR as versions
	From Revisions r
	INNER JOIN Documents d
		ON r.DocumentID = d.DocumentID
	INNER JOIN DocumentsInProjects dp
		ON d.DocumentID = dp.DocumentID
	INNER JOIN Projects p
		ON dp.ProjectID = p.ProjectID
	INNER JOIN ObjectType ot
    ON d.ObjectTypeID = ot.ObjectTypeID
WHERE
    -- Only real files
    ot.Description = 'Normal Document'

    -- File itself not deleted
    AND d.Deleted = 0

    -- File exists in at least one non-deleted folder
    AND EXISTS (
        SELECT 1
        FROM DocumentsInProjects dip
        INNER JOIN Projects p
            ON dip.ProjectID = p.ProjectID
        WHERE
            dip.DocumentID = d.DocumentID
            AND dip.Deleted = 0
            AND p.Deleted = 0
        )
)

Select
	COUNT(versions)	as number_of_versions,
	file_name,
	file_path
From Columns	
GROUP BY file_name, file_path
ORDER BY COUNT(versions) DESC
